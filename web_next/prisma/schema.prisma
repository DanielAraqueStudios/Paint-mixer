generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Command {
  id        Int      @id @default(autoincrement())
  color     String
  mlBlanca  Float
  mlRoja    Float
  mlVerde   Float
  mlAzul    Float
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
